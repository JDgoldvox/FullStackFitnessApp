@hostname=localhost:8000

### Get csrf token
# @name getCSRF

GET http://{{hostname}}/auth/csrf HTTP/1.1
Content-Type: application/json

### Authenticate
# @name loginRequest
@csrfToken={{getCSRF.response.body.csrftoken}}

POST http://{{hostname}}/auth/login/ HTTP/1.1
Content-Type: application/json
X-CSRFToken: {{csrfToken}}

{
    "username": "testuser",
    "password": "plokijuh"
}

###
# @name protectedRequest

GET http://{{hostname}}/api/steps/ HTTP/1.1
Content-Type: application/json

### refresh access token
# @name refreshToken

POST http://{{hostname}}/api/token/refresh/ HTTP/1.1
Content-Type: application/json

